OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MEMEAGENT_MODEL=qwen3.6-plus
MEMEAGENT_TEMPERATURE=0.2
MEMEAGENT_TIMEOUT=60
MEMEAGENT_MAX_TOKENS=1200
MEMEAGENT_MAX_RETRIES=0
MEMEAGENT_SEARCH_PROVIDER=ddgs
MEMEAGENT_SEARCH_API_KEY=
MEMEAGENT_ZHIHU_API_KEY=
MEMEAGENT_QWEN_SEARCH_API_KEY=
MEMEAGENT_QWEN_SEARCH_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MEMEAGENT_QWEN_SEARCH_MODEL=qwen-plus
MEMEAGENT_GLM_SEARCH_API_KEY=
MEMEAGENT_GLM_SEARCH_ENGINE=search_pro
MEMEAGENT_GLM_SEARCH_RECENCY_FILTER=noLimit
MEMEAGENT_GLM_SEARCH_CONTENT_SIZE=medium
MEMEAGENT_GLM_SEARCH_DOMAIN_FILTER=
MEMEAGENT_SEARCH_PROXY=
MEMEAGENT_SEARXNG_URL=http://localhost:8888
MEMEAGENT_SEARXNG_ENGINES=google,bing,brave,duckduckgo
MEMEAGENT_SEARXNG_WEB_CATEGORIES=general
MEMEAGENT_SEARXNG_NEWS_CATEGORIES=news
MEMEAGENT_SEARCH_MAX_RESULTS=5
MEMEAGENT_NEWS_MAX_RESULTS=5
MEMEAGENT_SEARCH_TIMEOUT=12
MEMEAGENT_SEARCH_COUNTRY=us
MEMEAGENT_SEARCH_LANG=en
MEMEAGENT_TAVILY_SEARCH_DEPTH=basic
MEMEAGENT_CACHE_ENABLED=true
MEMEAGENT_CACHE_DIR=.memeagent_cache
MEMEAGENT_SEARCH_CACHE_TTL_SECONDS=604800
MEMEAGENT_NEWS_CACHE_TTL_SECONDS=21600
MEMEAGENT_MEMORY_ENABLED=true
MEMEAGENT_MEMORY_DIR=.memeagent_memory
MEMEAGENT_MEMORY_RECALL_LIMIT=3
